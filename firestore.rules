rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ✅ Selon quand un compte a été créé, son rôle est stocké soit dans un tableau
    // "roles" (format actuel, utilisé par AdminUsers.tsx), soit dans un champ "role"
    // en chaîne (ancien format). Cette fonction vérifie les deux, pour ne jamais
    // refuser un accès légitime à cause de cette différence de schéma.
    // Appelée uniquement après avoir déjà vérifié request.auth != null.
    function isUserRole(role) {
      let profile = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return (profile.roles is list && role in profile.roles) || ('role' in profile && profile.role == role);
    }

    // ✅ Tout compte doit toujours porter le rôle "client" (les 3 autres rôles
    // s'additionnant par-dessus) : "Mon espace personnel" (protégé par role="client")
    // héberge désormais "Potes de grimpe", ouvert à tout le monde y compris le staff.
    // Garde-fou serveur en plus du verrou déjà posé dans AdminUsers.tsx, seul autre
    // point d'écriture du champ "roles".
    function hasClientRole(data) {
      return (data.roles is list && 'client' in data.roles) || ('role' in data && data.role == 'client');
    }

    // ✅ Un client ne peut valider les exercices d'une séance (client_course_results) que si :
    // elle a été activée par le moniteur ("séance du jour"), pas encore archivée, et le client
    // fait partie des participants sans s'être désisté (voir src/utils/courseSessionStatus.ts,
    // dont cette fonction reflète la logique côté client).
    function canValidateCourse(courseId) {
      let course = get(/databases/$(database)/documents/courses/$(courseId)).data;
      return 'activatedAt' in course &&
             !('archivedAt' in course) &&
             course.Participants.hasAny([request.auth.uid]) &&
             !(course.optedOut is list && course.optedOut.hasAny([request.auth.uid]));
    }

    // ========== 1. Utilisateurs ==========
    match /users/{userId} {
      allow read: if request.auth != null &&
                     (request.auth.uid == userId ||
                      isUserRole("admin") ||
                      isUserRole("moniteur") ||
                      isUserRole("ouvreur"));
      // ✅ "isUserRole(admin)" ajouté : AdminUsers.tsx (handleCreateUser) crée le
      // compte via une instance Firebase secondaire (pour ne pas déconnecter
      // l'admin), mais écrit le document Firestore "users/{nouvelUid}" avec la
      // session PRINCIPALE (celle de l'admin) — sans cette exception, request.auth.uid
      // (l'admin) ne correspond jamais à userId (le nouveau compte), et la création
      // d'utilisateur par un admin échoue systématiquement.
      allow create: if request.auth != null &&
                      (request.auth.uid == userId || isUserRole("admin")) &&
                      hasClientRole(request.resource.data);
      allow update: if request.auth != null &&
                      (
                        (isUserRole("admin") && hasClientRole(request.resource.data)) ||
                        (request.auth.uid == userId &&
                         // ✅ "levelOverride" ajouté : seul un admin doit pouvoir verrouiller/déverrouiller
                         // le niveau d'un client, sinon celui-ci pourrait geler son propre niveau à volonté.
                         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['inscritAuxCours', 'inscritAuxCompetitions', 'role', 'roles', 'levelOverride']))
                      );
      // ✅ Un admin peut désormais supprimer un compte (bloqué avant par "if false")
      allow delete: if request.auth != null && isUserRole("admin");
    }

    // ✅ Fiche publique allégée (prénom/nom/genre/date de naissance/opt-in) lue par le
    // classement des grimpeurs (ClientClassement.tsx). Un client ne peut pas lire le
    // document "users" d'un autre client (données sensibles : email, etc.), donc cette
    // fiche séparée, à laquelle n'importe quel utilisateur connecté peut avoir accès,
    // sert de source pour le classement sans jamais exposer le document complet.
    // Tenue à jour automatiquement par Register.tsx/ClientProfile.tsx/AdminUsers.tsx
    // au même moment que "users", pas de saisie séparée pour le client.
    match /classement_profiles/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
                     (request.auth.uid == userId || isUserRole("admin"));
    }

    // ✅ Annuaire public admin/moniteur/ouvreur (nom + rôles, rien d'autre), lu par
    // ClientMessages.tsx (choix du destinataire) et ClientDaily.tsx ("Créé par" un
    // bloc) : un client ne peut pas lister/lire la collection "users" d'un autre
    // utilisateur, donc cette fiche séparée (même pattern que "classement_profiles"
    // ci-dessus) sert de source sans jamais exposer d'autres données. Tenue à jour par
    // AdminUsers.tsx au même moment que "users" ; comptes déjà existants avant V2.1
    // rétro-remplis une fois via firestore-migration/migrate-staff-directory.js.
    match /staff_directory/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isUserRole("admin");
    }

    // ========== 2. Signalements ==========
    match /boulder_reports/{reportId} {
      allow read: if request.auth != null &&
                     (isUserRole("ouvreur") ||
                      isUserRole("admin"));
      allow create: if request.auth != null &&
                      (isUserRole("client") ||
                       isUserRole("admin"));
      allow update: if request.auth != null &&
                      (isUserRole("ouvreur") ||
                       isUserRole("admin"));
      allow delete: if request.auth != null &&
                      (isUserRole("admin"));
    }

    // ========== 3. Résultats des blocs (Client) ==========
    match /client_boulder_results/{docId} {
      allow read: if request.auth != null &&
                     (resource.data.userId == request.auth.uid ||
                      isUserRole("admin") ||
                      isUserRole("moniteur") ||
                      isUserRole("ouvreur"));
      allow create: if request.auth != null &&
                      request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null &&
                      (resource.data.userId == request.auth.uid ||
                       isUserRole("admin"));
      allow delete: if request.auth != null &&
                      (resource.data.userId == request.auth.uid ||
                       isUserRole("admin") ||
                       isUserRole("ouvreur"));
    }

    // ========== 4. Groupes ==========
    match /Groups/{groupId} {
      allow read: if request.auth != null &&
                     (resource.data.createdBy == request.auth.uid ||
                      resource.data.moniteurId == request.auth.uid ||
                      resource.data.students.hasAny([request.auth.uid]) ||
                      isUserRole("admin"));
      allow create: if request.auth != null &&
                      (isUserRole("moniteur") ||
                       isUserRole("admin"));
      allow update, delete: if request.auth != null &&
                              (request.auth.uid == resource.data.createdBy ||
                               request.auth.uid == resource.data.moniteurId ||
                               isUserRole("admin"));
    }

    // ========== 5. Cours ==========
    match /courses/{courseId} {
      allow read: if request.auth != null &&
                     (resource.data.createdBy == request.auth.uid ||
                      get(/databases/$(database)/documents/Groups/$(resource.data.groupId)).data.students.hasAny([request.auth.uid]) ||
                      isUserRole("admin"));
      allow create: if request.auth != null &&
                      (isUserRole("moniteur") ||
                       isUserRole("admin"));
      allow update: if request.auth != null &&
                      (request.auth.uid == resource.data.createdBy ||
                       get(/databases/$(database)/documents/Groups/$(resource.data.groupId)).data.moniteurId == request.auth.uid ||
                       isUserRole("admin") ||
                       // ✅ Un participant peut se désister/se réinscrire (uniquement le champ
                       // "optedOut"), tant que la séance n'a pas encore été activée.
                       (resource.data.Participants.hasAny([request.auth.uid]) &&
                        !('activatedAt' in resource.data) &&
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['optedOut'])));
      allow delete: if request.auth != null &&
                      (request.auth.uid == resource.data.createdBy ||
                       get(/databases/$(database)/documents/Groups/$(resource.data.groupId)).data.moniteurId == request.auth.uid ||
                       isUserRole("admin"));
    }

    // ========== 6. Exercices ==========
    match /exercises/{exerciseId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null &&
                                      (isUserRole("moniteur") ||
                                       isUserRole("admin") ||
                                       isUserRole("ouvreur"));
    }

    // ========== 7. Messages ==========
    match /messages/{messageId} {
      allow read: if request.auth != null &&
                     (resource.data.senderId == request.auth.uid ||
                      resource.data.receiverId == request.auth.uid ||
                      isUserRole("admin"));
      allow create: if request.auth != null &&
                     (request.resource.data.senderId == request.auth.uid);
      allow delete: if request.auth != null &&
                     (resource.data.senderId == request.auth.uid ||
                      isUserRole("admin"));
      allow update: if request.auth != null &&
                     resource.data.receiverId == request.auth.uid &&
                     request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
    }

    // ========== 8. Badges (Gestion par ouvreurs/moniteurs) ==========
    match /badges/{badgeId} {
      allow read: if request.auth != null; // Tout le monde peut lire les badges disponibles
      allow create, update, delete: if request.auth != null &&
                                      (isUserRole("ouvreur") ||
                                       isUserRole("admin") ||
                                       isUserRole("moniteur"));
    }

    // ========== 9. Badges des clients ==========
    match /client_badges/{clientBadgeId} {
      allow read: if request.auth != null &&
                     (resource.data.userId == request.auth.uid || // Le client voit ses propres badges
                      isUserRole("admin") ||
                      isUserRole("moniteur") ||
                      isUserRole("ouvreur"));
      allow create: if request.auth != null &&
                      (isUserRole("admin") ||
                       isUserRole("moniteur") ||
                       isUserRole("ouvreur"));
      allow update, delete: if false; // Interdit la modification/suppression des badges attribués
    }

    // ========== 10. Diplômes ==========
    match /diplomas/{diplomaId} {
      allow read: if request.auth != null &&
                     (resource.data.userId == request.auth.uid || // Le client voit ses propres diplômes
                      isUserRole("admin") ||
                      isUserRole("moniteur") ||
                      isUserRole("ouvreur"));
      allow create: if request.auth != null &&
                      (isUserRole("admin") ||
                       isUserRole("moniteur") ||
                       isUserRole("ouvreur"));
      allow update, delete: if false; // Interdit la modification/suppression des diplômes
    }

    // ========== 11. Collections Ouvreur (existantes) ==========
    match /boulders/{docId} {
      // ✅ "moniteur" ajouté : StatsList.tsx (page Moniteur > Stats) lit cette
      // collection sans filtre au chargement, dans le même bloc try/catch que tout
      // le reste de la page — un refus de permission ici empêchait donc l'affichage
      // de TOUTES les stats (exercices, résultats, badges), pas seulement les blocs.
      allow read: if request.auth != null &&
                    (isUserRole("ouvreur") ||
                     isUserRole("admin") ||
                     isUserRole("client") ||
                     isUserRole("moniteur"));
      allow create, update, delete: if request.auth != null &&
                                      (isUserRole("ouvreur") ||
                                       isUserRole("admin"));
    }

    match /client_course_results/{docId} {
      // ✅ "read" et "write" ouverts aussi au client lui-même : c'est justement
      // ClientCourseSession.tsx/ClientStats.tsx (pages clientes) qui lisent/écrivent
      // ici pour l'utilisateur connecté — resterait sinon en échec de permission.
      allow read: if request.auth != null &&
                    (resource.data.userId == request.auth.uid ||
                     isUserRole("ouvreur") ||
                     isUserRole("admin") ||
                     isUserRole("moniteur"));
      allow write: if request.auth != null &&
                     (isUserRole("ouvreur") ||
                      isUserRole("admin") ||
                      isUserRole("moniteur") ||
                      (isUserRole("client") &&
                       request.resource.data.userId == request.auth.uid &&
                       canValidateCourse(request.resource.data.courseId)));
    }

    // ========== 12. Collections Compétitions ==========
    match /competitions/{docId} {
      allow read: if request.auth != null;
      allow create, delete: if request.auth != null &&
                              (isUserRole("admin") ||
                               isUserRole("ouvreur"));
      allow update: if request.auth != null &&
                      (isUserRole("admin") ||
                       isUserRole("ouvreur") ||
                       // ✅ Un client qui s'inscrit incrémente registered_count
                       // (ClientCompetitions.tsx) : restreint à ce seul champ.
                       (isUserRole("client") &&
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['registered_count'])));
    }

    match /competition_participants/{docId} {
      allow read: if request.auth != null &&
                    (resource.data.user_id == request.auth.uid ||
                     isUserRole("admin") ||
                     isUserRole("ouvreur"));
      allow create: if request.auth != null &&
                      (request.resource.data.user_id == request.auth.uid ||
                       isUserRole("admin") ||
                       isUserRole("ouvreur"));
      allow update, delete: if request.auth != null &&
                              (isUserRole("admin") ||
                               isUserRole("ouvreur"));
    }

    match /competition_results/{docId} {
      allow read: if request.auth != null &&
                    (resource.data.user_id == request.auth.uid ||
                     isUserRole("admin") ||
                     isUserRole("ouvreur"));
      allow create: if request.auth != null &&
                      (request.resource.data.user_id == request.auth.uid ||
                       isUserRole("admin") ||
                       isUserRole("ouvreur"));
      allow update: if request.auth != null &&
                      (resource.data.user_id == request.auth.uid ||
                       isUserRole("admin") ||
                       isUserRole("ouvreur"));
      allow delete: if request.auth != null &&
                      (isUserRole("admin") ||
                       isUserRole("ouvreur"));
    }

    // ========== 13. Équipement ==========
    match /equipment/{docId} {
      // ✅ "moniteur" ajouté : ExerciseForm.tsx (page Moniteur > Exercices) lit et
      // écrit cette collection pour proposer/ajouter des équipements, pas seulement ouvreur/admin.
      allow read, write: if request.auth != null &&
                           (isUserRole("ouvreur") ||
                            isUserRole("admin") ||
                            isUserRole("moniteur"));
    }

    // ========== 14. Contenu de la page d'accueil ==========
    match /homeContent/{docId} {
      allow read, write: if request.auth != null &&
                           isUserRole("admin");
    }

    // ========== 15. Informations pour les clients (bandeau d'accueil) ==========
    match /announcements/{announcementId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && isUserRole("admin");
    }

    // ========== 16. Potes de grimpe (amitiés + statuts sociaux) ==========
    // ✅ Identifiant de relation déterministe (les deux uids triés puis concaténés),
    // pour qu'une seule relation existe entre deux personnes quel que soit qui a
    // envoyé la demande — évite les doublons "A→B" et "B→A".
    function friendPairId(uidA, uidB) {
      return uidA < uidB ? uidA + '_' + uidB : uidB + '_' + uidA;
    }

    // ✅ Vérifie qu'une amitié ACCEPTÉE existe entre l'utilisateur connecté et otherUid,
    // utilisée pour autoriser la lecture du statut "je grimpe"/"ma prochaine session"
    // d'un ami. "exists()" d'abord : un get() sur un document absent ferait échouer
    // toute la règle plutôt que de simplement refuser proprement l'accès.
    function isAcceptedFriend(otherUid) {
      let path = /databases/$(database)/documents/friendships/$(friendPairId(request.auth.uid, otherUid));
      return exists(path) && get(path).data.status == 'accepted';
    }

    match /friendships/{pairId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.uids;
      allow create: if request.auth != null &&
                      request.auth.uid in request.resource.data.uids &&
                      request.resource.data.uids.size() == 2 &&
                      request.resource.data.uids[0] != request.resource.data.uids[1] &&
                      pairId == friendPairId(request.resource.data.uids[0], request.resource.data.uids[1]) &&
                      request.resource.data.requestedBy == request.auth.uid &&
                      request.resource.data.status == 'pending';
      // ✅ Seule la personne qui N'A PAS envoyé la demande peut l'accepter, pour ne
      // jamais permettre de s'auto-confirmer sa propre demande d'ami.
      allow update: if request.auth != null &&
                      request.auth.uid in resource.data.uids &&
                      request.auth.uid != resource.data.requestedBy &&
                      resource.data.status == 'pending' &&
                      request.resource.data.status == 'accepted';
      // ✅ Sert à la fois à refuser une demande reçue et à retirer un ami accepté :
      // dans les deux cas, n'importe laquelle des deux personnes peut supprimer la
      // relation.
      allow delete: if request.auth != null && request.auth.uid in resource.data.uids;
    }

    // ✅ Statut éphémère "je suis en train de grimper", tenu à jour par son
    // propriétaire uniquement. La péremption (3h) est calculée à l'affichage côté
    // client (voir Friends.tsx) plutôt que par une tâche planifiée serveur.
    match /climbing_status/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAcceptedFriend(uid));
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ✅ "Ma prochaine session" : jour/créneau déclarés librement par l'utilisateur,
    // sans lien avec les séances moniteur (courses) déjà existantes.
    match /next_sessions/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAcceptedFriend(uid));
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ========== 17. Par défaut ==========
    match /{otherDocument=**} {
      allow read, write: if false;
    }
  }
}
