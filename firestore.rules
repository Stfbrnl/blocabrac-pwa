rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========== 1. Utilisateurs ==========
    match /users/{userId} {
      allow read: if request.auth != null &&
                     (request.auth.uid == userId ||
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" ||
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "moniteur" ||
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "ouvreur");
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null &&
                      (
                        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" ||
                        (request.auth.uid == userId &&
                         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['inscritAuxCours', 'inscritAuxCompetitions', 'role']))
                      );
      allow delete: if false;
    }

    // ========== 2. Signalements ==========
    match /boulder_reports/{reportId} {
      allow read: if request.auth != null &&
                     (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "ouvreur" ||
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin");
      allow create: if request.auth != null &&
                      (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "client" ||
                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin");
      allow update: if request.auth != null &&
                      (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "ouvreur" ||
                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin");
      allow delete: if request.auth != null &&
                      (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin");
    }

    // ========== 3. Résultats des blocs (Client) ==========
    match /client_boulder_results/{docId} {
      allow read: if request.auth != null &&
                     (resource.data.userId == request.auth.uid ||
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" ||
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "moniteur" ||
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "ouvreur");
      allow create: if request.auth != null &&
                      request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null &&
                      (resource.data.userId == request.auth.uid ||
                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin");
      allow delete: if request.auth != null &&
                      (resource.data.userId == request.auth.uid ||
                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" ||
                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "ouvreur");
    }

    // ========== 4. Groupes ==========
    match /Groups/{groupId} {
      allow read: if request.auth != null &&
                     (resource.data.createdBy == request.auth.uid ||
                      resource.data.moniteurId == request.auth.uid ||
                      resource.data.students.hasAny([request.auth.uid]) ||
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin");
      allow create: if request.auth != null &&
                      (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "moniteur" ||
                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin");
      allow update, delete: if request.auth != null &&
                              (request.auth.uid == resource.data.createdBy ||
                               request.auth.uid == resource.data.moniteurId ||
                               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin");
    }

    // ========== 5. Cours ==========
    match /courses/{courseId} {
      allow read: if request.auth != null &&
                     (resource.data.createdBy == request.auth.uid ||
                      get(/databases/$(database)/documents/Groups/$(resource.data.groupId)).data.students.hasAny([request.auth.uid]) ||
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin");
      allow create: if request.auth != null &&
                      (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "moniteur" ||
                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin");
      allow update, delete: if request.auth != null &&
                              (request.auth.uid == resource.data.createdBy ||
                               get(/databases/$(database)/documents/Groups/$(resource.data.groupId)).data.moniteurId == request.auth.uid ||
                               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin");
    }

    // ========== 6. Exercices ==========
    match /exercises/{exerciseId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null &&
                                      (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "moniteur" ||
                                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" ||
                                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "ouvreur");
    }

    // ========== 7. Messages ==========
    match /messages/{messageId} {
      allow read: if request.auth != null &&
                     (resource.data.senderId == request.auth.uid ||
                      resource.data.receiverId == request.auth.uid ||
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin");
      allow create: if request.auth != null &&
                     (request.resource.data.senderId == request.auth.uid);
      allow delete: if request.auth != null &&
                     (resource.data.senderId == request.auth.uid ||
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin");
      allow update: if request.auth != null &&
                     resource.data.receiverId == request.auth.uid &&
                     request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
    }

    // ========== 8. Badges (Gestion par ouvreurs/moniteurs) ==========
    match /badges/{badgeId} {
      allow read: if request.auth != null; // Tout le monde peut lire les badges disponibles
      allow create, update, delete: if request.auth != null &&
                                      (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "ouvreur" ||
                                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" ||
                                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "moniteur");
    }

    // ========== 9. Badges des clients ==========
    match /client_badges/{clientBadgeId} {
      allow read: if request.auth != null &&
                     (resource.data.userId == request.auth.uid || // Le client voit ses propres badges
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" ||
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "moniteur" ||
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "ouvreur");
      allow create: if request.auth != null &&
                      (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" ||
                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "moniteur" ||
                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "ouvreur");
      allow update, delete: if false; // Interdit la modification/suppression des badges attribués
    }

    // ========== 10. Diplômes ==========
    match /diplomas/{diplomaId} {
      allow read: if request.auth != null &&
                     (resource.data.userId == request.auth.uid || // Le client voit ses propres diplômes
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" ||
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "moniteur" ||
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "ouvreur");
      allow create: if request.auth != null &&
                      (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" ||
                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "moniteur" ||
                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "ouvreur");
      allow update, delete: if false; // Interdit la modification/suppression des diplômes
    }

    // ========== 11. Collections Ouvreur (existantes) ==========
    match /boulders/{docId} {
      allow read: if request.auth != null &&
                    (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "ouvreur" ||
                     get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" ||
                     get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "client");
      allow create, update, delete: if request.auth != null &&
                                      (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "ouvreur" ||
                                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin");
    }

    match /client_course_results/{docId} {
      allow read: if request.auth != null &&
                    (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "ouvreur" ||
                     get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" ||
                     get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "moniteur");
      allow write: if request.auth != null &&
                     (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "ouvreur" ||
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" ||
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "moniteur");
    }

    // ========== 12. Collections Compétitions ==========
    match /competitions/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null &&
                                    (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" ||
                                     get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "ouvreur");
    }

    match /competition_participants/{docId} {
      allow read: if request.auth != null &&
                    (resource.data.user_id == request.auth.uid ||
                     get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" ||
                     get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "ouvreur");
      allow create: if request.auth != null &&
                      (request.resource.data.user_id == request.auth.uid ||
                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" ||
                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "ouvreur");
      allow update, delete: if request.auth != null &&
                              (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" ||
                               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "ouvreur");
    }

    match /competition_results/{docId} {
      allow read: if request.auth != null &&
                    (resource.data.user_id == request.auth.uid ||
                     get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" ||
                     get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "ouvreur");
      allow create: if request.auth != null &&
                      (request.resource.data.user_id == request.auth.uid ||
                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" ||
                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "ouvreur");
      allow update: if request.auth != null &&
                      (resource.data.user_id == request.auth.uid ||
                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" ||
                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "ouvreur");
      allow delete: if request.auth != null &&
                      (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" ||
                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "ouvreur");
    }

    // ========== 13. Équipement ==========
    match /equipment/{docId} {
      allow read, write: if request.auth != null &&
                           (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "ouvreur" ||
                            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin");
    }

    // ========== 14. Contenu de la page d'accueil ==========
    match /homeContent/{docId} {
      allow read, write: if request.auth != null &&
                           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // ========== 15. Par défaut ==========
    match /{otherDocument=**} {
      allow read, write: if false;
    }
  }
}