rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ✅ Selon quand un compte a été créé, son rôle est stocké soit dans un tableau
    // "roles" (format actuel, utilisé par AdminUsers.tsx), soit dans un champ "role"
    // en chaîne (ancien format). Cette fonction vérifie les deux, pour ne jamais
    // refuser un accès légitime à cause de cette différence de schéma.
    // Appelée uniquement après avoir déjà vérifié request.auth != null.
    function isUserRole(role) {
      let profile = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return (profile.roles is list && role in profile.roles) || profile.role == role;
    }

    // ✅ Un client ne peut valider les exercices d'une séance (client_course_results) que si :
    // elle a été activée par le moniteur ("séance du jour"), pas encore archivée, et le client
    // fait partie des participants sans s'être désisté (voir src/utils/courseSessionStatus.ts,
    // dont cette fonction reflète la logique côté client).
    function canValidateCourse(courseId) {
      let course = get(/databases/$(database)/documents/courses/$(courseId)).data;
      return 'activatedAt' in course &&
             !('archivedAt' in course) &&
             course.Participants.hasAny([request.auth.uid]) &&
             !(course.optedOut is list && course.optedOut.hasAny([request.auth.uid]));
    }

    // ========== 1. Utilisateurs ==========
    match /users/{userId} {
      allow read: if request.auth != null &&
                     (request.auth.uid == userId ||
                      isUserRole("admin") ||
                      isUserRole("moniteur") ||
                      isUserRole("ouvreur"));
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null &&
                      (
                        isUserRole("admin") ||
                        (request.auth.uid == userId &&
                         // ✅ "levelOverride" ajouté : seul un admin doit pouvoir verrouiller/déverrouiller
                         // le niveau d'un client, sinon celui-ci pourrait geler son propre niveau à volonté.
                         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['inscritAuxCours', 'inscritAuxCompetitions', 'role', 'roles', 'levelOverride']))
                      );
      // ✅ Un admin peut désormais supprimer un compte (bloqué avant par "if false")
      allow delete: if request.auth != null && isUserRole("admin");
    }

    // ========== 2. Signalements ==========
    match /boulder_reports/{reportId} {
      allow read: if request.auth != null &&
                     (isUserRole("ouvreur") ||
                      isUserRole("admin"));
      allow create: if request.auth != null &&
                      (isUserRole("client") ||
                       isUserRole("admin"));
      allow update: if request.auth != null &&
                      (isUserRole("ouvreur") ||
                       isUserRole("admin"));
      allow delete: if request.auth != null &&
                      (isUserRole("admin"));
    }

    // ========== 3. Résultats des blocs (Client) ==========
    match /client_boulder_results/{docId} {
      allow read: if request.auth != null &&
                     (resource.data.userId == request.auth.uid ||
                      isUserRole("admin") ||
                      isUserRole("moniteur") ||
                      isUserRole("ouvreur"));
      allow create: if request.auth != null &&
                      request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null &&
                      (resource.data.userId == request.auth.uid ||
                       isUserRole("admin"));
      allow delete: if request.auth != null &&
                      (resource.data.userId == request.auth.uid ||
                       isUserRole("admin") ||
                       isUserRole("ouvreur"));
    }

    // ========== 4. Groupes ==========
    match /Groups/{groupId} {
      allow read: if request.auth != null &&
                     (resource.data.createdBy == request.auth.uid ||
                      resource.data.moniteurId == request.auth.uid ||
                      resource.data.students.hasAny([request.auth.uid]) ||
                      isUserRole("admin"));
      allow create: if request.auth != null &&
                      (isUserRole("moniteur") ||
                       isUserRole("admin"));
      allow update, delete: if request.auth != null &&
                              (request.auth.uid == resource.data.createdBy ||
                               request.auth.uid == resource.data.moniteurId ||
                               isUserRole("admin"));
    }

    // ========== 5. Cours ==========
    match /courses/{courseId} {
      allow read: if request.auth != null &&
                     (resource.data.createdBy == request.auth.uid ||
                      get(/databases/$(database)/documents/Groups/$(resource.data.groupId)).data.students.hasAny([request.auth.uid]) ||
                      isUserRole("admin"));
      allow create: if request.auth != null &&
                      (isUserRole("moniteur") ||
                       isUserRole("admin"));
      allow update: if request.auth != null &&
                      (request.auth.uid == resource.data.createdBy ||
                       get(/databases/$(database)/documents/Groups/$(resource.data.groupId)).data.moniteurId == request.auth.uid ||
                       isUserRole("admin") ||
                       // ✅ Un participant peut se désister/se réinscrire (uniquement le champ
                       // "optedOut"), tant que la séance n'a pas encore été activée.
                       (resource.data.Participants.hasAny([request.auth.uid]) &&
                        !('activatedAt' in resource.data) &&
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['optedOut'])));
      allow delete: if request.auth != null &&
                      (request.auth.uid == resource.data.createdBy ||
                       get(/databases/$(database)/documents/Groups/$(resource.data.groupId)).data.moniteurId == request.auth.uid ||
                       isUserRole("admin"));
    }

    // ========== 6. Exercices ==========
    match /exercises/{exerciseId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null &&
                                      (isUserRole("moniteur") ||
                                       isUserRole("admin") ||
                                       isUserRole("ouvreur"));
    }

    // ========== 7. Messages ==========
    match /messages/{messageId} {
      allow read: if request.auth != null &&
                     (resource.data.senderId == request.auth.uid ||
                      resource.data.receiverId == request.auth.uid ||
                      isUserRole("admin"));
      allow create: if request.auth != null &&
                     (request.resource.data.senderId == request.auth.uid);
      allow delete: if request.auth != null &&
                     (resource.data.senderId == request.auth.uid ||
                      isUserRole("admin"));
      allow update: if request.auth != null &&
                     resource.data.receiverId == request.auth.uid &&
                     request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
    }

    // ========== 8. Badges (Gestion par ouvreurs/moniteurs) ==========
    match /badges/{badgeId} {
      allow read: if request.auth != null; // Tout le monde peut lire les badges disponibles
      allow create, update, delete: if request.auth != null &&
                                      (isUserRole("ouvreur") ||
                                       isUserRole("admin") ||
                                       isUserRole("moniteur"));
    }

    // ========== 9. Badges des clients ==========
    match /client_badges/{clientBadgeId} {
      allow read: if request.auth != null &&
                     (resource.data.userId == request.auth.uid || // Le client voit ses propres badges
                      isUserRole("admin") ||
                      isUserRole("moniteur") ||
                      isUserRole("ouvreur"));
      allow create: if request.auth != null &&
                      (isUserRole("admin") ||
                       isUserRole("moniteur") ||
                       isUserRole("ouvreur"));
      allow update, delete: if false; // Interdit la modification/suppression des badges attribués
    }

    // ========== 10. Diplômes ==========
    match /diplomas/{diplomaId} {
      allow read: if request.auth != null &&
                     (resource.data.userId == request.auth.uid || // Le client voit ses propres diplômes
                      isUserRole("admin") ||
                      isUserRole("moniteur") ||
                      isUserRole("ouvreur"));
      allow create: if request.auth != null &&
                      (isUserRole("admin") ||
                       isUserRole("moniteur") ||
                       isUserRole("ouvreur"));
      allow update, delete: if false; // Interdit la modification/suppression des diplômes
    }

    // ========== 11. Collections Ouvreur (existantes) ==========
    match /boulders/{docId} {
      allow read: if request.auth != null &&
                    (isUserRole("ouvreur") ||
                     isUserRole("admin") ||
                     isUserRole("client"));
      allow create, update, delete: if request.auth != null &&
                                      (isUserRole("ouvreur") ||
                                       isUserRole("admin"));
    }

    match /client_course_results/{docId} {
      // ✅ "read" et "write" ouverts aussi au client lui-même : c'est justement
      // ClientCourseSession.tsx/ClientStats.tsx (pages clientes) qui lisent/écrivent
      // ici pour l'utilisateur connecté — resterait sinon en échec de permission.
      allow read: if request.auth != null &&
                    (resource.data.userId == request.auth.uid ||
                     isUserRole("ouvreur") ||
                     isUserRole("admin") ||
                     isUserRole("moniteur"));
      allow write: if request.auth != null &&
                     (isUserRole("ouvreur") ||
                      isUserRole("admin") ||
                      isUserRole("moniteur") ||
                      (isUserRole("client") &&
                       request.resource.data.userId == request.auth.uid &&
                       canValidateCourse(request.resource.data.courseId)));
    }

    // ========== 12. Collections Compétitions ==========
    match /competitions/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null &&
                                    (isUserRole("admin") ||
                                     isUserRole("ouvreur"));
    }

    match /competition_participants/{docId} {
      allow read: if request.auth != null &&
                    (resource.data.user_id == request.auth.uid ||
                     isUserRole("admin") ||
                     isUserRole("ouvreur"));
      allow create: if request.auth != null &&
                      (request.resource.data.user_id == request.auth.uid ||
                       isUserRole("admin") ||
                       isUserRole("ouvreur"));
      allow update, delete: if request.auth != null &&
                              (isUserRole("admin") ||
                               isUserRole("ouvreur"));
    }

    match /competition_results/{docId} {
      allow read: if request.auth != null &&
                    (resource.data.user_id == request.auth.uid ||
                     isUserRole("admin") ||
                     isUserRole("ouvreur"));
      allow create: if request.auth != null &&
                      (request.resource.data.user_id == request.auth.uid ||
                       isUserRole("admin") ||
                       isUserRole("ouvreur"));
      allow update: if request.auth != null &&
                      (resource.data.user_id == request.auth.uid ||
                       isUserRole("admin") ||
                       isUserRole("ouvreur"));
      allow delete: if request.auth != null &&
                      (isUserRole("admin") ||
                       isUserRole("ouvreur"));
    }

    // ========== 13. Équipement ==========
    match /equipment/{docId} {
      allow read, write: if request.auth != null &&
                           (isUserRole("ouvreur") ||
                            isUserRole("admin"));
    }

    // ========== 14. Contenu de la page d'accueil ==========
    match /homeContent/{docId} {
      allow read, write: if request.auth != null &&
                           isUserRole("admin");
    }

    // ========== 15. Informations pour les clients (bandeau d'accueil) ==========
    match /announcements/{announcementId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && isUserRole("admin");
    }

    // ========== 16. Par défaut ==========
    match /{otherDocument=**} {
      allow read, write: if false;
    }
  }
}
