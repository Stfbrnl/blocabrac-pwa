    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-firebase-hooks": "^5.1.1",
    "react-router-dom": "^7.15.1",
    "vite-plugin-pwa": "^1.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "18.3.1",
    "@types/react-dom": "18.3.1",
